{
	"extends": "astro/tsconfigs/strict",
  "exclude": ["dist", "dist-book", "node_modules"],
	"compilerOptions": {
		"paths": {
			"@components/*": ["./src/components/*"],
			"@layouts/*": ["./src/layouts/*"],
			"@styles/*": ["./src/styles/*"],
			"@i18n/*": ["./src/i18n/*"],
			"@lib/*": ["./src/lib/*"]
		}
	}
}
