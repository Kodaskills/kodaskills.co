---
import Text from "@components/typography/Text.astro";
import Title from "@components/typography/Title.astro";

/**
 * SectionTitle — numbered section heading followed by a full-width rule.
 * Used to open major content sections on the home page and inner pages.
 */
interface Props {
  number: string;
  title: string;
}

const { number, title } = Astro.props;
---

<section>
	<Title as="h2" variant="h1" class="uppercase tracking-widest flex items-center gap-4">
		<Text as="span" color="primary">{number}</Text>
    {title}
	</Title>
  <hr class="h-px w-full bg-outline-variant mt-4" />
</section>
