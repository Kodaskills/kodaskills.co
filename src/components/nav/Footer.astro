---
/**
 * Footer — left margin tracks the sidebar state via $store.sidebar (Alpine).
 * 2-column grid layout: brand left, 3-column nav grid right.
 */
import Icon from "@components/primitives/Icon.astro";
import Link from "@components/typography/Link.astro";
import Text from "@components/typography/Text.astro";
import Title from "@components/typography/Title.astro";
import { getI18n } from "@i18n/index";

const { _, locale } = getI18n();
const year = new Date().getFullYear();

const legalLinks =
  locale === "fr"
    ? {
        privacy: "/fr/politique-de-confidentialite",
        legal: "/fr/mentions-legales",
        terms: "/fr/cgu",
      }
    : {
        privacy: "/privacy-policy",
        legal: "/legal-notice",
        terms: "/terms-of-use",
      };
---

<footer class="lg:ml-20 bg-surface border-t border-outline-variant">
  <section class="py-12 px-6 grid grid-cols-1 md:grid-cols-2 gap-12">
    <section aria-label="Brand">
      <Title as="p" variant="h4" class="text-on-surface tracking-widest mb-4 uppercase">
        KODASKILLS
      </Title>
      <Text variant="xs" class="mb-6 leading-relaxed text-outline">
        {_("OPERATOR-GRADE PRECISION FOR ENTERPRISE ARCHITECTURE. WE BUILD WHAT OTHERS ONLY THEORIZE.")}
      </Text>
      <Text variant="captionMono" class="text-primary">
        EST. 2024 / V6.0.4
      </Text>
    </section>

    <nav class="grid grid-cols-3 gap-8" aria-label={_("Footer navigation")}>
      <section class="space-y-4">
        <Title as="h3" variant="h4" class="text-primary">{_("Your Journey")}</Title>
        <ul class="space-y-2 font-sans text-xs">
          <li>
            <Link href="#" class="flex items-center gap-2">
              <span class="font-mono text-[10px] text-primary/60 shrink-0">01</span>
              {_("Expertise")}
            </Link>
          </li>
          <li>
            <Link href="#" class="flex items-center gap-2">
              <span class="font-mono text-[10px] text-primary/60 shrink-0">02</span>
              {_("Approach")}
            </Link>
          </li>
          <li>
            <Link href="#" class="flex items-center gap-2">
              <span class="font-mono text-[10px] text-primary/60 shrink-0">03</span>
              {_("Methodology")}
            </Link>
          </li>
          <li>
            <Link href="#" class="flex items-center gap-2">
              <span class="font-mono text-[10px] text-primary/60 shrink-0">04</span>
              {_("Contact")}
            </Link>
          </li>
        </ul>
      </section>

      <section class="space-y-4">
        <Title as="h3" variant="h4" class="text-primary">{_("Connect")}</Title>
        <ul class="space-y-2 font-sans text-xs">
          <li>
            <Link href="https://www.linkedin.com/company/kodaskills/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2">
              <Icon name="social-linkedin" size={14} class="shrink-0" />
              LinkedIn
            </Link>
          </li>
          <li>
            <Link href="https://github.com/Kodaskills/kodaskills.co" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2">
              <Icon name="social-github" size={14} class="shrink-0" />
              GitHub
            </Link>
          </li>
          <li>
            <Link href="#" class="flex items-center gap-2">
              <Icon name="social-x" size={14} class="shrink-0" />
              X
            </Link>
          </li>
        </ul>
      </section>

      <section class="space-y-4">
        <Title as="h3" variant="h4" class="text-primary">{_("Legal")}</Title>
        <ul class="space-y-2 font-sans text-xs">
          <li>
            <Link href={legalLinks.privacy} class="flex items-center gap-2">
              <Icon name="card-encrypted" size={14} class="shrink-0" />
              {_("Privacy")}
            </Link>
          </li>
          <li>
            <Link href={legalLinks.legal} class="flex items-center gap-2">
              <Icon name="card-shield" size={14} class="shrink-0" />
              {_("Legal")}
            </Link>
          </li>
          <li>
            <Link href={legalLinks.terms} class="flex items-center gap-2">
              <Icon name="card-verified" size={14} class="shrink-0" />
              {_("Terms of Op")}
            </Link>
          </li>
        </ul>
      </section>

    </nav>
  </section>

  <section class="border-t border-outline-variant px-6 h-11 flex items-center">
    <Text variant="captionMono" class="text-outline">
      © {year} KODASKILLS_OPERATIONS. ALL_RIGHTS_RESERVED.
    </Text>
  </section>
</footer>
