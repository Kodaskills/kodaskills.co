---
import Icon from "@components/primitives/Icon.astro";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"span"> {}

const { class: className = "", ...attrs } = Astro.props;
---

<section
  class:list={["hidden md:block relative", className]}
  style="width: 60px; height: 32px;"
  {...attrs}
  x-data={`{ open: false, ready: false, snap: false, currentLang: '${Astro.currentLocale ?? "en"}' }`}
  x-init="
    const prev = sessionStorage.getItem('ks-lang');
    sessionStorage.setItem('ks-lang', currentLang);
    if (prev && prev !== currentLang) {
      requestAnimationFrame(() => requestAnimationFrame(() => { ready = true; }));
    } else {
      snap = true;
      ready = true;
    }
  "
  @mouseenter="open = true"
  @mouseleave="open = false"
  role="radiogroup"
  aria-label="Language"
>
  <div
    class="absolute top-0 left-0 overflow-hidden"
    style="width: 60px; border-radius: 0; background: var(--color-surface); box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-outline-variant) 40%, transparent); z-index: 50;"
    :style="open ? 'height: 64px' : 'height: 32px'"
  >
    <menu
      class="flex flex-col"
      :style="ready ? 'transform: translateY(0)' : 'transform: translateY(32px)'"
    >
      <li>
        <button
          @click={`window.location.href = $store.lang.pathFor('${Astro.currentLocale ?? "en"}')`}
          role="radio"
          aria-checked="true"
          class="text-primary shrink-0 h-8 px-3 flex items-center gap-2 text-[10px] font-mono font-bold cursor-pointer w-full"
          title="Switch to English"
          aria-label="Switch to English"
        >
          <Icon name="flag-en" size={14} />
          EN
        </button>
      </li>

      <li>
        <button
          @click={`window.posthog?.capture('language_changed', { from_lang: '${Astro.currentLocale ?? "en"}', to_lang: 'fr' }); window.location.href = $store.lang.pathFor('fr')`}
          role="radio"
          aria-checked="false"
          class="text-outline hover:text-on-surface shrink-0 h-8 px-3 flex items-center gap-2 transition-colors duration-150 text-[10px] font-mono font-bold cursor-pointer w-full"
          style="filter: grayscale(1);"
          title="Passer en français"
          aria-label="Passer en français"
        >
          <Icon name="flag-fr" size={14} />
          FR
        </button>
      </li>
    </menu>
  </div>
</section>
