---
import ThemeToggle from "@components/nav/ThemeToggle.astro";
import Icon from "@components/primitives/Icon.astro";
import Popover from "@components/primitives/Popover.astro";
import Tooltip from "@components/primitives/Tooltip.astro";
import { getI18n } from "@i18n/index";
import type { IconName } from "@lib/icons";

interface Props {
  activePage: "home" | "expertises" | "approach" | "contact" | "none";
  /** Whether links are actually clickable. Defaults to true. */
  clickable?: boolean;
}

const { activePage, clickable = true } = Astro.props;
const { lp } = getI18n();

const navItems: {
  key: string;
  icon: IconName;
  label: string;
  tooltip: string;
  href: string;
}[] = [
  {
    key: "leadership",
    icon: "card-leadership",
    label: "Leadership",
    tooltip: "CTO as a Service · Strategy · Tech Lead",
    href: "#",
  },
  {
    key: "product",
    icon: "card-product",
    label: "Product",
    tooltip: "Full & Part-time Product and Software Development",
    href: "#",
  },
  {
    key: "infrastructure",
    icon: "card-dns",
    label: "Ops",
    tooltip: "Architecture · Scaling · Cloud · On-Prem",
    href: "#",
  },
  {
    key: "ai",
    icon: "card-ai",
    label: "AI",
    tooltip: "AI Adoption · Workflows · Upskilling",
    href: "#",
  },
  {
    key: "security",
    icon: "card-encrypted",
    label: "Security",
    tooltip: "Security · Compliance · Monitoring",
    href: "#",
  },
  {
    key: "finops",
    icon: "card-finops",
    label: "FinOps",
    tooltip: "Cloud Cost Optimization · Budgeting · Governance",
    href: "#",
  },
  {
    key: "advisory",
    icon: "card-handshake",
    label: "Advisory",
    tooltip: "On-Demand Expertise",
    href: "#",
  },
];
---

<aside class="hidden lg:flex flex-col fixed left-0 top-0 h-full w-20 bg-surface z-[51] border-r border-outline-variant">
	<!-- Logo -->
	<div class="h-16 flex items-center justify-center shrink-0">
		<a href={lp("/")} class="text-primary font-headline font-bold tracking-widest text-2xl leading-none">
			K
		</a>
	</div>

	<!-- Nav items -->
	<nav class="flex-1 py-4 font-headline text-xs tracking-tight">
		<div class="flex justify-center py-2">
			<span class="uppercase text-[7px] tracking-widest font-bold text-secondary/40">Services</span>
		</div>
		{navItems.map((item) => {
			const isActive = activePage === item.key;
			return (
				<Popover title={item.label} content={item.tooltip} placement="right" class="block">
					<a
						href={item.href}
						data-nav-key={item.key}
						data-active-class="bg-surface-container text-primary border-l-4 border-primary"
						data-inactive-class="text-outline hover:bg-surface-container hover:text-primary"
						class={`flex flex-col items-center justify-center py-4 px-2 gap-1 transition-all ${
							isActive
								? "bg-surface-container text-primary border-l-4 border-primary"
								: "text-outline hover:bg-surface-container hover:text-primary"
						}`}
					>
						<Icon name={item.icon} size={18} class="shrink-0" />
						<span class="uppercase text-[7px] tracking-widest font-bold">{item.label.split(" ")[0]}</span>
					</a>
				</Popover>
			);
		})}
	</nav>

	<!-- Bottom controls -->
	<div class="mt-auto py-2 w-full font-headline text-[10px] uppercase tracking-widest">
		<Tooltip content="LinkedIn" placement="right" class="block">
			<a
				href="https://www.linkedin.com/company/kodaskills/"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="LinkedIn"
				class="flex items-center justify-center py-2 text-outline hover:text-on-surface transition-colors"
			>
				<Icon name="social-linkedin" size={18} class="shrink-0" />
			</a>
		</Tooltip>

		<Tooltip content="GitHub" placement="right" class="block">
			<a
				href="https://github.com/Kodaskills/kodaskills.co"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="GitHub"
				class="flex items-center justify-center py-2 text-outline hover:text-on-surface transition-colors"
			>
				<Icon name="social-github" size={18} class="shrink-0" />
			</a>
		</Tooltip>

		<div class="mx-3 my-1 border-t border-outline-variant"></div>
		<ThemeToggle />
	</div>
</aside>
