---
import Icon from "@components/primitives/Icon.astro";
import { getI18n } from "@i18n/index";
import type { IconName } from "@lib/icons";

interface Props {
  activePage: "home" | "expertises" | "approach" | "contact" | "none";
}

const { activePage } = Astro.props;
const { _, lp } = getI18n();

const items: { key: string; icon: IconName; label: string }[] = [
  { key: "home", icon: "nav-skills", label: _("Home") },
  { key: "expertises", icon: "nav-memory", label: "Svc" },
  { key: "approach", icon: "nav-lab", label: "Audit" },
  { key: "contact", icon: "nav-security", label: "Contact" },
];
---

<nav
  class="md:hidden fixed bottom-0 left-0 w-full bg-surface border-t border-outline-variant flex justify-around items-center h-16 z-50"
>
  {
    items.map((item) => (
      <a
        href={lp(item.key === "home" ? "/" : `/${item.key}`)}
        data-nav-key={item.key}
        data-active-class="text-primary"
        data-inactive-class="text-outline"
        class={`flex flex-col items-center gap-1 ${activePage === item.key ? "text-primary" : "text-outline"}`}
      >
        <Icon name={item.icon} size={24} />
        <span class="text-[8px] font-headline uppercase">{item.label}</span>
      </a>
    ))
  }
</nav>
