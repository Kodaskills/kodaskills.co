---
import Title from "@components/typography/Title.astro";
/**
 * Showcase — renders a labelled collection of component instances.
 *
 * layout:
 *   "row"   (default) — flex row, wraps on small screens
 *   "grid"            — 2-column grid, for placement comparisons
 *   "stack"           — vertical column, full-width (AlertBar, cards…)
 *
 * type:
 *   "hover"           — wraps each item in a HOVER trigger (Tooltip, Popover…)
 *   "text"            — renders component with text as slot (typography)
 *   null    (default) — renders component directly (Tag, Badge, Button…)
 *
 * containerClassName / itemClassName — optional overrides for the layout container
 * and per-item wrapper. Only use when the built-in layouts don't fit.
 */
import { activateLingui } from "@i18n/index";
import StoryDecorator from "./StoryDecorator.astro";

interface Item {
  label: string;
  props: Record<string, unknown>;
  text?: string;
}

interface Group {
  type: string;
  items: Item[];
}

interface Props {
  // biome-ignore lint/suspicious/noExplicitAny: Astro has no Component type
  component: any;
  items?: Item[];
  groups?: Group[];
  layout?: "row" | "grid" | "stack";
  type?: "hover" | "text";
  containerClassName?: string;
  itemClassName?: string;
}

const CONTAINER: Record<string, string> = {
  row: "flex gap-12 items-end justify-center flex-wrap",
  grid: "grid grid-cols-2 gap-24",
  stack: "flex flex-col gap-4 w-full",
};

const ITEM: Record<string, string> = {
  row: "flex flex-col items-center gap-3",
  grid: "flex flex-col items-center gap-3",
  stack: "flex flex-col items-center gap-3",
};

const {
  component: Component,
  items = [],
  groups,
  layout = "row",
  type,
  containerClassName,
  itemClassName,
} = Astro.props;
const containerClass = containerClassName ?? CONTAINER[layout] ?? CONTAINER.row;
const itemClass = itemClassName ?? ITEM[layout] ?? ITEM.row;

await activateLingui("en");
---

<StoryDecorator padding="py-20 px-16">
  {
    groups && groups.length > 0 ? (
      <section class="flex flex-col gap-12">
        {groups.map((group) => (
          <article>
            <header>
              <Title as="h3" variant="h4" class="col-span-full mb-4">
                {group.type.charAt(0).toUpperCase() + group.type.slice(1)}
              </Title>
            </header>
            <ul class={containerClass}>
              {group.items.map(({ label, props, text }) => (
                <li class={itemClass}>
                  {!type && <Component {...props} />}
                  {type === "text" && (
                    <Component {...props}>{text ?? props?.text}</Component>
                  )}
                  {type === "hover" && (
                    <div
                      class="relative inline-flex cursor-pointer"
                      role="button"
                      tabindex="0"
                    >
                      <div class="bg-surface-container border border-outline-variant text-on-surface font-mono font-bold uppercase tracking-widest text-[10px] px-6 py-2 pointer-events-none select-none">
                        HOVER
                      </div>
                      <div class="absolute inset-0 [&>*]:block [&>*]:w-full [&>*]:h-full">
                        <Component {...props} />
                      </div>
                    </div>
                  )}
                  <div class="font-mono text-[8px] uppercase tracking-widest text-outline">
                    {label}
                  </div>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </section>
    ) : (
      <ul class={containerClass}>
        {items.map(({ label, props, text }) => (
          <li class={itemClass}>
            {!type && <Component {...props} />}
            {type === "text" && (
              <Component {...props}>{text ?? props?.text}</Component>
            )}
            {type === "hover" && (
              <div
                class="relative inline-flex cursor-pointer"
                role="button"
                tabindex="0"
              >
                <div class="bg-surface-container border border-outline-variant text-on-surface font-mono font-bold uppercase tracking-widest text-[10px] px-6 py-2 pointer-events-none select-none">
                  HOVER
                </div>
                <div class="absolute inset-0 [&>*]:block [&>*]:w-full [&>*]:h-full">
                  <Component {...props} />
                </div>
              </div>
            )}
            <div class="font-mono text-[8px] uppercase tracking-widest text-outline">
              {label}
            </div>
          </li>
        ))}
      </ul>
    )
  }
</StoryDecorator>
