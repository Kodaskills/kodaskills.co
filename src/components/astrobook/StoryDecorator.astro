---
/**
 * StoryDecorator — canvas for stories.
 * Provides background, min-height, padding, and centering.
 * Layout is owned by Showcase (or the story itself).
 */
interface Props {
  scheme?: "dark" | "light";
  padding?: string;
}

const { scheme = "dark", padding = "p-8" } = Astro.props;
---

<main class={`k-book-container ${scheme} bg-surface min-h-screen ${padding} flex items-center justify-center`}>
  <slot />
</main>

<script>
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    const link = target.closest("a");
    const button = target.closest("button");
    const container = target.closest(".k-book-container");
    if (!container) return;

    if (link && !link.href?.startsWith("https")) {
      link.href = "#";
      e.preventDefault();
      e.stopPropagation();
    }

    if (button) {
      const onclick = button.getAttribute("onclick") || "";
      const ariaAttr = button.getAttribute("@click") || "";
      if (onclick.includes("window.location") || onclick.includes("location.href") ||
          ariaAttr.includes("window.location") || ariaAttr.includes("location.href")) {
        e.preventDefault();
        e.stopPropagation();
      }
    }
  }, true);
</script>
