---
// PostHog analytics snippet
// Uses is:inline to prevent Astro from processing the script (avoids TypeScript errors on window.posthog)
---
<script is:inline define:vars={{ apiKey: import.meta.env.PUBLIC_POSTHOG_PROJECT_TOKEN, apiHost: import.meta.env.PUBLIC_POSTHOG_HOST }}>
  !((t,e)=> {var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=(i,s,a)=> {function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.crossOrigin="anonymous",p.async=!0,p.src=s.api_host+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=(t)=> {var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=()=> u.toString(1)+".people (stub)",o="capture identify alias people.set people.set_once set_config register register_once unregister opt_out_capturing has_opted_out_capturing opt_in_capturing reset isFeatureEnabled onFeatureFlags getFeatureFlag getFeatureFlagPayload reloadFeatureFlags group updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures getActiveMatchingSurveys getSurveys getNextSurveyStep onSessionId".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)})(document,window.posthog||[]);
  posthog.init(apiKey || '', {
    api_host: apiHost || '',
    defaults: '2026-01-30',
    opt_out_capturing_by_default: true,
  });

  // Sync PostHog with cookie consent decisions (vanilla-cookieconsent v3 events)
  window.addEventListener('cc:onConsent', (evt) => {
    var accepted = evt.detail && evt.detail.cookie && evt.detail.cookie.categories || [];
    if (accepted.indexOf('analytics') !== -1) {
      posthog.opt_in_capturing();
    }
  });

  // Close button (X) on the consent modal defaults to "reject all" in the library.
  // Intercept it: clone the button to strip the original listener, then accept all.
  window.addEventListener('cc:onModalReady', (evt) => {
    if (!evt.detail || evt.detail.modalName !== 'consentModal') return;
    var closeBtn = document.querySelector('.cm__btn--close');
    if (!closeBtn) return;
    var replacement = closeBtn.cloneNode(true);
    replacement.addEventListener('click', () => {
      var acceptAllBtn = document.querySelector('.cm__btn[data-role="all"]');
      if (acceptAllBtn) acceptAllBtn.click();
    });
    closeBtn.parentNode.replaceChild(replacement, closeBtn);
  });

  window.addEventListener('cc:onChange', (evt) => {
    var accepted = evt.detail && evt.detail.cookie && evt.detail.cookie.categories || [];
    if (accepted.indexOf('analytics') !== -1) {
      posthog.opt_in_capturing();
    } else {
      posthog.opt_out_capturing();
    }
  });
</script>
