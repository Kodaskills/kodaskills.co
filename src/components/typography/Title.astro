---
/**
 * Title — heading component with variant sizes.
 *
 * Variants:
 *  - "headline": Hero/display text (text-5xl md:text-8xl/tight)
 *  - "display": Large display text (text-4xl/tight)
 *  - "h1": Page title (text-3xl/tight)
 *  - "h2": Section title (text-2xl/tight)
 *  - "h3": Subsection title (text-xl/snug)
 *  - "h4": Card title (text-lg/snug)
 *  - "h5": Small heading (text-base/snug)
 *  - "h6": Extra small heading (text-sm/snug)
 *
 */
export interface Props {
  as?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6" | "span" | "p";
  variant?: "headline" | "display" | "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
  class?: string;
}

const { as: Tag = "h2", variant = "h2", class: className = "" } = Astro.props;

const variants: Record<string, string> = {
  headline: "font-headline text-5xl md:text-8xl font-bold tracking-tighter leading-none",
  display: "font-heading text-4xl leading-tight font-bold",
  h1: "font-heading text-3xl leading-tight tracking-tight font-bold",
  h2: "font-heading text-2xl leading-tight tracking-tight font-bold",
  h3: "font-heading text-xl leading-snug font-semibold",
  h4: "font-heading text-lg leading-snug font-semibold",
  h5: "font-heading text-base leading-snug font-semibold",
  h6: "font-heading text-sm leading-snug font-semibold",
};
---

<Tag class:list={[variants[variant], className]}>
  <slot />
</Tag>
