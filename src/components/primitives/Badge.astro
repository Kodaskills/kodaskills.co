---
/**
 * Badge — status indicator with a colored dot and a label.
 *
 * Variants:
 *  - "primary"   : cyan dot, pulsing   — active / advisory (default)
 *  - "secondary" : gray dot, static    — idle / neutral
 *  - "tertiary"  : amber dot, pulsing  — warning
 *  - "error"     : red dot, pulsing    — critical / error
 */
interface Props {
  label: string;
  variant?: "primary" | "secondary" | "tertiary" | "error";
}

const { label, variant = "primary" } = Astro.props;

const dotClasses: Record<string, string> = {
  primary: "bg-primary animate-pulse",
  secondary: "bg-secondary",
  tertiary: "bg-tertiary animate-pulse",
  error: "bg-error animate-pulse",
};
---

<div
  class="inline-flex items-center gap-2 px-3 py-1 bg-surface-container-high border border-outline-variant"
>
  <span class={`w-2 h-2 ${dotClasses[variant]}`}></span>
  <span class="font-label text-[10px] uppercase tracking-[0.2em] text-on-surface-variant">
    {label}
  </span>
</div>
