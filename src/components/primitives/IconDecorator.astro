---
/**
 * IconDecorator — renders all icons from the registry, optionally grouped by type.
 *
 * Pattern: (type)-name → when `type` is provided, only icons matching
 * that prefix are shown. When `type` is omitted, groups by all types.
 */
import { ICON_REGISTRY, type IconName } from "@lib/icons";
import Icon from "./Icon.astro";

interface Props {
  /** Filter to a specific type prefix (e.g. "theme", "nav", "card") */
  type?: string;
}

const { type } = Astro.props;
const entries = Object.entries(ICON_REGISTRY);

// Group by prefix
const groups: Record<string, [string, string][]> = {};
for (const [key, value] of entries) {
  const prefix = key.split("-")[0] ?? "other";
  if (!groups[prefix]) groups[prefix] = [];
  groups[prefix].push([key, value]);
}

// Sort groups: preserve registry order of first appearance
const groupOrder = ["theme", "nav", "cta", "card", "social", "flag", "alert"];
const sortedKeys = Object.keys(groups).sort((a, b) => {
  const ai = groupOrder.indexOf(a);
  const bi = groupOrder.indexOf(b);
  return (ai === -1 ? 999 : ai) - (bi === -1 ? 999 : bi);
});

// If type is specified, only show that group
const activeGroups: Record<string, [string, string][]> = {};
if (type) {
  activeGroups[type] = groups[type] ?? [];
} else {
  for (const key of sortedKeys) {
    activeGroups[key] = groups[key];
  }
}
const activeKeys = type ? [type] : sortedKeys.filter((k) => groups[k]);
---

<div class="sidebar-decorator-root bg-surface" style="padding: 2rem;">
  <div class="icon-groups">
    {activeKeys.map((t) => {
      const label = t.charAt(0).toUpperCase() + t.slice(1);
      return (
        <div class="icon-group">
          <h3 class="group-label">{label}</h3>
          <div class="icon-grid">
            {activeGroups[t].map(([name]) => {
              const displayName = name
                .replace(/-/g, " ")
                .replace(/\b\w/g, (c) => c.toUpperCase());
              return (
                <div class="icon-card">
                  <Icon name={name as IconName} size={32} />
                  <span class="icon-name">{displayName}</span>
                  <span class="icon-key">{name}</span>
                </div>
              );
            })}
          </div>
        </div>
      );
    })}
  </div>
</div>

<style is:global>
  .sidebar-decorator-root {
    width: 100%;
  }
  .icon-groups {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .icon-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .group-label {
    font-size: 0.75rem;
    font-weight: 700;
    font-family: monospace;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgb(68 216 241);
    margin: 0;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgb(128 128 128 / 0.2);
  }
  .icon-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 0.75rem;
  }
  .icon-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    padding: 0.85rem 0.5rem;
    border: 1px solid rgb(128 128 128 / 0.15);
    border-radius: 0.5rem;
    background: rgb(255 255 255 / 0.02);
    transition: background 0.15s;
  }
  .icon-card:hover {
    background: rgb(255 255 255 / 0.06);
  }
  .icon-name {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: capitalize;
    color: rgb(200 200 200);
  }
  .icon-key {
    font-family: monospace;
    font-size: 0.55rem;
    color: rgb(150 150 150 / 0.6);
  }
</style>
