---
/**
 * IconDecorator — renders a grid of all icons from the registry.
 */
import { ICON_REGISTRY, type IconName } from "@lib/icons";
import Icon from "./Icon.astro";

interface Props {
  scheme?: "dark" | "light";
}

const { scheme = "dark" } = Astro.props;
---

<div class={`${scheme} bg-surface`} style="padding: 2rem;">
  <div class="icon-grid">
    {Object.entries(ICON_REGISTRY).map(([name]) => {
      const label = name
        .replace(/-/g, " ")
        .replace(/\b\w/g, (c) => c.toUpperCase());
      return (
        <div class="icon-card">
          <Icon name={name as IconName} size={32} />
          <span class="icon-label">{label}</span>
          <span class="icon-key">{name}</span>
        </div>
      );
    })}
  </div>
</div>

<style is:global>
  .icon-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 1rem;
  }
  .icon-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 0.5rem;
    border: 1px solid rgb(128 128 128 / 0.2);
    border-radius: 0.5rem;
    background: rgb(255 255 255 / 0.03);
    transition: background 0.15s;
  }
  .icon-card:hover {
    background: rgb(255 255 255 / 0.06);
  }
  .icon-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: capitalize;
    color: rgb(200 200 200);
  }
  .icon-key {
    font-family: monospace;
    font-size: 0.55rem;
    color: rgb(150 150 150 / 0.7);
  }
</style>
