---
/**
 * BlockDecorator — single decorator for all nav/ components in Astrobook.
 *
 * Activates i18n, scopes fixed-position nav components into bounded previews,
 * centered both horizontally and vertically.
 */
import { activateLingui } from "@i18n/index";

await activateLingui("en");
---

<div class="block-decorator-root bg-surface">
  <div class="frame">
    <slot />
  </div>
</div>

<script>
  // Intercept all clicks on links inside the frame and prevent navigation
  document.addEventListener("click", (e) => {
    const link = (e.target as HTMLElement).closest("a");
    if (!link) return;
    const frame = link.closest(".block-decorator-root .frame");
    if (!frame) return;
    e.preventDefault();
    e.stopPropagation();
  }, true);
</script>

<style is:global>
  /* ═══ Root ═══ */
  .block-decorator-root {
    --sb-height: 600px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    padding: 2rem;
    min-height: var(--sb-height);
  }

  /* ═══ Frame base ═══ */
  .block-decorator-root .frame {
    position: relative;
    overflow: hidden;
    border: 1px solid rgb(128 128 128 / 0.3);
    border-radius: 0.5rem;
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
  }

  /* Kill ALL fixed/absolute positioning from Tailwind on the slotted element */
  .block-decorator-root .frame > :is(aside, header, footer, nav) {
    position: relative !important;
    top: auto !important;
    left: auto !important;
    right: auto !important;
    bottom: auto !important;
    z-index: auto !important;
  }

  /* ═══ Sidebar frame (detects <aside>) ═══ */
  .block-decorator-root .frame:has(> aside) {
    width: 5rem;
    height: var(--sb-height);
  }
  .block-decorator-root .frame:has(> aside) > aside {
    display: flex !important;
    width: 100% !important;
    height: 100% !important;
    min-height: var(--sb-height) !important;
    margin: 0 !important;
  }

  /* ═══ Header frame (detects <header>) ═══ */
  .block-decorator-root .frame:has(> header) {
    width: 72rem;
    max-width: 100%;
  }
  .block-decorator-root .frame:has(> header) > header {
    display: flex !important;
    flex-direction: row !important;
    justify-content: space-between !important;
    align-items: center !important;
    width: 100% !important;
    height: auto !important;
    min-height: 4rem !important;
    padding: 0 1.5rem !important;
    box-sizing: border-box !important;
  }
  .block-decorator-root .frame:has(> header) > header > .flex-1 {
    flex: 1 !important;
    min-width: 0 !important;
  }
  .block-decorator-root .frame:has(> header) > header #main-nav {
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
    gap: 2rem !important;
    flex-shrink: 0 !important;
  }

  /* ═══ Footer frame (detects <footer>) ═══ */
  .block-decorator-root .frame:has(> footer) {
    width: 72rem;
    max-width: 100%;
    min-height: 24rem;
  }
  .block-decorator-root .frame:has(> footer) > footer {
    display: block !important;
    width: 100% !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
  }

  /* ═══ BottomNav frame (detects <nav>) ═══ */
  .block-decorator-root .frame:has(> nav) {
    width: 375px;
    height: 667px;
    border-radius: 0.75rem;
  }
  .block-decorator-root .frame:has(> nav) > nav {
    display: flex !important;
    width: 100% !important;
    position: absolute !important;
    bottom: 0 !important;
    left: 0 !important;
  }
</style>
