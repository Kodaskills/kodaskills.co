---
import AlertBar from "@components/blocks/AlertBar.astro";
import PageHeader from "@components/blocks/PageHeader.astro";
import PageHero from "@components/blocks/PageHero.astro";
import Icon from "@components/primitives/Icon.astro";
import { useI18n } from "@i18n/index";
import BaseLayout from "@layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [{ params: { locale: undefined } }, { params: { locale: "fr" } }];
}

const { _, lp } = await useI18n(Astro.currentLocale);
---

<BaseLayout title={_("KODASKILLS | Approach & Methodology")} activePage="approach">
  <PageHero>
    <PageHeader badge={_("OPERATIONAL_FRAMEWORK")}>
      <Fragment slot="title">
        {_("PRECISION THROUGH")}<br />
        <span class="text-primary">{_("STRUCTURAL RIGOR")}</span><br />
      </Fragment>
      <Fragment slot="description">
        {_("We do not believe in generic consulting. Kodaskills operates as a high-density technical partner, applying surgical methodology to complex engineering challenges.")}
      </Fragment>
    </PageHeader>
  </PageHero>

  <section class="py-24 px-6 md:px-12 grid grid-cols-1 md:grid-cols-12 gap-0 border border-outline-variant relative">
    <article class="md:col-span-4 border-r border-b md:border-b-0 border-outline-variant p-8 bg-surface-container hover:bg-surface-container-high transition-colors group">
      <header class="flex justify-between items-start mb-12">
        <output class="text-3xl font-headline font-bold text-outline-variant group-hover:text-primary transition-colors">01</output>
        <Icon name="card-audit" class="text-primary" />
      </header>
      <h3 class="font-headline text-xl font-bold mb-4 tracking-tight">{_("SYSTEM_AUDIT")}</h3>
      <p class="text-sm font-body text-on-surface-variant mb-6 leading-relaxed">
        {_("Full-spectrum diagnostic of infrastructure, code integrity, and architectural bottlenecks. 48-hour rapid intake cycle.")}
      </p>
      <ul class="space-y-2">
        <li class="flex items-center gap-2 text-[10px] font-mono text-outline">
          <span class="w-1 h-1 bg-primary"></span> LOG_ANALYSIS_V4
        </li>
        <li class="flex items-center gap-2 text-[10px] font-mono text-outline">
          <span class="w-1 h-1 bg-primary"></span> STACK_DECONSTRUCTION
        </li>
      </ul>
    </article>

    <article class="md:col-span-4 border-r border-b md:border-b-0 border-outline-variant p-8 bg-surface-container-high relative">
      <span class="absolute top-0 right-0 p-2 text-[10px] font-mono text-primary opacity-50">CORE_MODULE</span>
      <header class="flex justify-between items-start mb-12">
        <output class="text-3xl font-headline font-bold text-primary">02</output>
        <Icon name="card-hub" class="text-primary" />
      </header>
      <h3 class="font-headline text-xl font-bold mb-4 tracking-tight text-on-surface">{_("INTEGRATED_SUPPORT")}</h3>
      <p class="text-sm font-body text-on-surface-variant mb-6 leading-relaxed">
        {_("Long-term structural alignment. We embed as senior technical leads within your existing ecosystem to ensure sustained evolution.")}
      </p>
      <ul class="flex flex-wrap gap-2">
        <li class="text-[10px] font-mono border border-outline-variant px-2 py-1 text-on-surface-variant">SCALABILITY_L2</li>
        <li class="text-[10px] font-mono border border-outline-variant px-2 py-1 text-on-surface-variant">TECH_DEBT_REDUCTION</li>
      </ul>
    </article>

    <article class="md:col-span-4 p-8 bg-surface-container hover:bg-surface-container-high transition-colors group">
      <header class="flex justify-between items-start mb-12">
        <output class="text-3xl font-headline font-bold text-outline-variant group-hover:text-tertiary transition-colors">03</output>
        <Icon name="card-bolt" class="text-tertiary" />
      </header>
      <h3 class="font-headline text-xl font-bold mb-4 tracking-tight">{_("CRISIS_TASK_FORCE")}</h3>
      <p class="text-sm font-body text-on-surface-variant mb-6 leading-relaxed">
        {_("Immediate intervention for critical system failures or high-stakes launches. Deployment of elite senior engineers within 4 hours.")}
      </p>
      <aside class="bg-surface-container-lowest border border-error/30 p-3">
        <p class="text-[10px] font-mono text-error flex items-center gap-2">
          <Icon name="alert-warning" size={14} /> EMERGENCY_PROTOCOL_ENABLED
        </p>
      </aside>
    </article>
  </section>

  <section class="mt-24 relative z-10">
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <section>
        <h2 class="font-headline text-3xl font-bold mb-8 border-b border-primary w-fit pr-12 pb-2">
          {_("PARTNER_ARCHETYPE")}
        </h2>
        <ul class="space-y-8">
          <li class="flex gap-6">
            <figure class="shrink-0 w-12 h-12 border border-outline-variant flex items-center justify-center text-primary">
              <Icon name="card-security" />
            </figure>
            <section>
              <h4 class="font-headline font-bold text-sm tracking-widest uppercase mb-2">{_("Authority_Lock")}</h4>
              <p class="text-sm text-on-surface-variant leading-relaxed">
                {_("We provide absolute clarity in decision-making. No ambiguous recommendations, only technical directives backed by data.")}
              </p>
            </section>
          </li>
          <li class="flex gap-6">
            <figure class="shrink-0 w-12 h-12 border border-outline-variant flex items-center justify-center text-primary">
              <Icon name="card-analytics" />
            </figure>
            <section>
              <h4 class="font-headline font-bold text-sm tracking-widest uppercase mb-2">{_("Deep_Diagnostic")}</h4>
              <p class="text-sm text-on-surface-variant leading-relaxed">
                {_("Surface-level fixes are rejected. We investigate the root architectural cause of every failure point.")}
              </p>
            </section>
          </li>
          <li class="flex gap-6">
            <figure class="shrink-0 w-12 h-12 border border-outline-variant flex items-center justify-center text-primary">
              <Icon name="card-handshake" />
            </figure>
            <section>
              <h4 class="font-headline font-bold text-sm tracking-widest uppercase mb-2">{_("Reliability_Mesh")}</h4>
              <p class="text-sm text-on-surface-variant leading-relaxed">
                {_("Our partnership is built on uptime and output. We function as a fail-safe layer for your core product team.")}
              </p>
            </section>
          </li>
        </ul>
      </section>

      <figure class="relative aspect-square bg-surface-container border border-outline-variant overflow-hidden">
        <span aria-hidden="true" class="absolute inset-0 technical-grid-dots opacity-20"></span>
        <span class="absolute inset-0 flex items-center justify-center"></span>
          <svg class="w-full h-full p-12" viewBox="0 0 400 400" role="img" aria-label="System architecture diagram">
            <circle cx="200" cy="200" r="180" fill="none" stroke="#484848" stroke-dasharray="8 8" stroke-width="1" />
            <rect x="150" y="150" width="100" height="100" fill="none" stroke="#44d8f1" stroke-width="2" />
            <text x="200" y="205" text-anchor="middle" fill="#44d8f1" font-family="Space Grotesk" font-size="10" font-weight="bold">CORE_LOGIC</text>
            <line x1="200" y1="150" x2="200" y2="80" stroke="#484848" stroke-width="1" />
            <rect x="180" y="60" width="40" height="20" fill="#191a1a" stroke="#484848" />
            <text x="200" y="73" text-anchor="middle" fill="#767575" font-family="Inter" font-size="6">INPUT</text>
            <line x1="250" y1="200" x2="320" y2="200" stroke="#484848" stroke-width="1" />
            <rect x="320" y="190" width="40" height="20" fill="#191a1a" stroke="#484848" />
            <text x="340" y="203" text-anchor="middle" fill="#767575" font-family="Inter" font-size="6">PROCESS</text>
            <line x1="200" y1="250" x2="200" y2="320" stroke="#484848" stroke-width="1" />
            <rect x="180" y="320" width="40" height="20" fill="#191a1a" stroke="#484848" />
            <text x="200" y="333" text-anchor="middle" fill="#767575" font-family="Inter" font-size="6">OUTPUT</text>
            <circle cx="200" cy="80" r="3" fill="#44d8f1" class="animate-pulse" />
          </svg>
        </span>
        <figcaption class="absolute bottom-4 left-4 font-mono text-[8px] text-outline">
          COORD: 45.332 // -12.441<br />
          STATUS: CALIBRATING...
          <span class="absolute top-4 right-4 font-mono text-[8px] text-primary">
            ENCRYPTION_ACTIVE
          </span>
        </figcaption>
      </figure>
    </section>
  </section>

  <section class="mt-24 relative z-10">
    <AlertBar
      title={_("EMERGENCY_ACCESS")}
      description={_("Critical system failure? Our rapid response task force is available for immediate deployment.")}
      href={lp("/contact")}
      ctaLabel={_("INITIATE_CONTACT")}
      variant="tertiary"
      icon="alert-warning"
    />
  </section>
</BaseLayout>
